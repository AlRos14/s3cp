#!/usr/bin/env bash
# s3cp — Transfer files between local machine and EC2 instances via S3 + SSM
#
# Usage:
#   s3cp configure                                      # interactive setup
#   s3cp push <local-path> <instance> <remote-path>    # local → instance
#   s3cp pull <instance> <remote-path> [local-path]    # instance → local
#
# <instance> can be an Instance ID (i-0abc...) or a Name tag (partial, case-insensitive)

set -euo pipefail

S3CP_VERSION="1.0.0"
CONFIG_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/s3cp/config"

# ── Load config file (key=value, # comments ignored) ────────
load_config() {
  [[ ! -f "$CONFIG_FILE" ]] && return 0
  while IFS='=' read -r key value; do
    [[ "$key" =~ ^[[:space:]]*# || -z "$key" ]] && continue
    key="${key// /}"; value="${value// /}"
    case "$key" in
      bucket)  _CF_BUCKET="$value"  ;;
      region)  _CF_REGION="$value"  ;;
      profile) _CF_PROFILE="$value" ;;
      user)    _CF_USER="$value"    ;;
      timeout) _CF_TIMEOUT="$value" ;;
    esac
  done < "$CONFIG_FILE"
}

load_config

# Priority: env var > config file > built-in default
S3_BUCKET="${S3CP_BUCKET:-${_CF_BUCKET:-}}"
AWS_REGION="${S3CP_REGION:-${_CF_REGION:-eu-south-2}}"
AWS_PROFILE="${S3CP_PROFILE:-${_CF_PROFILE:-}}"
SSM_USER="${SSM_USER:-${_CF_USER:-ubuntu}}"
SSM_TIMEOUT="${S3CP_TIMEOUT:-${_CF_TIMEOUT:-300}}"
RECURSIVE=false
NO_CLEANUP=false

# ── Colours ──────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  CYAN=$'\033[0;36m'; BOLD=$'\033[1m'; DIM=$'\033[2m'; RESET=$'\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; CYAN=''; BOLD=''; DIM=''; RESET=''
fi

err()  { echo -e "${RED}✖ $*${RESET}" >&2; }
info() { echo -e "${CYAN}ℹ $*${RESET}"; }
ok()   { echo -e "${GREEN}✔ $*${RESET}"; }
warn() { echo -e "${YELLOW}⚠ $*${RESET}"; }
step() { echo -e "${BOLD}▶ $*${RESET}"; }

# ── Helpers ──────────────────────────────────────────────────
require_cmd() {
  command -v "$1" &>/dev/null || { err "Required command not found: $1"; exit 1; }
}

# Build common AWS CLI flags
aws_opts() {
  local opts="--region ${AWS_REGION}"
  [[ -n "$AWS_PROFILE" ]] && opts+=" --profile ${AWS_PROFILE}"
  echo "$opts"
}

usage() {
  cat <<EOF
${BOLD}s3cp${RESET} v${S3CP_VERSION} — Transfer files between local machine and EC2 instances

${BOLD}USAGE${RESET}
  s3cp configure
  s3cp push [-r] <local-path> <instance> [remote-path]
  s3cp pull [-r] <instance> <remote-path> [local-path]

${BOLD}ARGUMENTS${RESET}
  <instance>     Instance ID (i-0abc...) or Name tag (partial match)
  <remote-path>  Full path on the instance (default: /home/<user>/)
  <local-path>   Local destination (defaults to current directory)

${BOLD}OPTIONS${RESET}
  -r, --recursive     Transfer directories (auto tar/untar)
  -b, --bucket NAME   S3 bucket override
  -R, --region REGION AWS region override
  -p, --profile NAME  AWS CLI profile override
  -u, --user USER     OS user on instance override
  -t, --timeout SECS  SSM command timeout override
  --no-cleanup        Keep the S3 temp object after transfer
  -V, --version       Show version
  -h, --help          Show this help

${BOLD}CONFIG FILE${RESET}  ${CONFIG_FILE}
  bucket=nutraliascp
  region=eu-south-2
  user=ubuntu
  timeout=300
  # profile=myprofile

  Priority: flag > environment variable > config file > built-in default

${BOLD}EXAMPLES${RESET}
  s3cp configure
  s3cp push db-backup.sql <instance> /home/ubuntu/
  s3cp pull <instance> /var/log/syslog ./
  s3cp push -r ./my-app <instance> /home/ubuntu/
  s3cp push -b mybucket -R us-east-1 data.csv <instance> /tmp/

  <instance> accepts both Name tags (partial match) and Instance IDs:
    s3cp push file.sql my-server /tmp/          # name tag (partial)
    s3cp push file.sql i-0abc1234def56789a /tmp/ # instance ID
EOF
  exit "${1:-0}"
}

# ── CONFIGURE: interactive setup ────────────────────────────
do_configure() {
  echo -e "${BOLD}s3cp configure${RESET}"
  echo -e "${DIM}Config file: ${CONFIG_FILE}${RESET}"
  echo ""

  local cur_bucket="${S3_BUCKET}"
  local cur_region="${AWS_REGION}"
  local cur_profile="${AWS_PROFILE:-}"
  local cur_user="${SSM_USER}"
  local cur_timeout="${SSM_TIMEOUT}"

  read -rp "S3 bucket [${cur_bucket}]: " inp_bucket
  read -rp "AWS region [${cur_region}]: " inp_region
  read -rp "AWS profile (leave blank for default) [${cur_profile:-none}]: " inp_profile
  read -rp "Remote OS user [${cur_user}]: " inp_user
  read -rp "SSM timeout (seconds) [${cur_timeout}]: " inp_timeout

  local bucket="${inp_bucket:-$cur_bucket}"
  local region="${inp_region:-$cur_region}"
  local profile="${inp_profile:-$cur_profile}"
  local user="${inp_user:-$cur_user}"
  local timeout="${inp_timeout:-$cur_timeout}"

  mkdir -p "$(dirname "$CONFIG_FILE")"

  cat > "$CONFIG_FILE" <<EOF
# s3cp configuration
# Generated by: s3cp configure
bucket=${bucket}
region=${region}
user=${user}
timeout=${timeout}
EOF

  [[ -n "$profile" ]] && echo "profile=${profile}" >> "$CONFIG_FILE"

  echo ""
  ok "Config saved to ${CONFIG_FILE}"
}

# Resolve instance target to ID + Name
resolve_instance() {
  local target="$1"

  if [[ "$target" =~ ^i-[0-9a-f]+$ ]]; then
    INSTANCE_ID="$target"
    INSTANCE_NAME=$(aws ec2 describe-instances --instance-ids "$target" \
      --query "Reservations[].Instances[].Tags[?Key=='Name']|[0][0].Value" \
      --output text $(aws_opts) 2>/dev/null || true)
    [[ "$INSTANCE_NAME" == "None" || -z "$INSTANCE_NAME" ]] && INSTANCE_NAME=""
    return 0
  fi

  # Name tag search (case-insensitive partial match)
  local results
  results=$(aws ec2 describe-instances \
    --query "Reservations[].Instances[?State.Name=='running'].{ID:InstanceId,Name:Tags[?Key=='Name']|[0].Value}" \
    --output json $(aws_opts) | jq -r --arg pat "$target" \
      '.[][] | select(.Name != null) | select(.Name | ascii_downcase | contains($pat | ascii_downcase)) | "\(.ID)\t\(.Name)"')

  local count
  count=$(echo "$results" | grep -c . 2>/dev/null || echo 0)

  if [[ $count -eq 0 ]]; then
    err "No running instance found matching '${target}'"
    exit 1
  elif [[ $count -eq 1 ]]; then
    IFS=$'\t' read -r INSTANCE_ID INSTANCE_NAME <<< "$results"
    return 0
  else
    info "Multiple instances match '${target}':"
    local i=0
    local matches=()
    while IFS= read -r line; do
      matches+=("$line")
      IFS=$'\t' read -r id name <<< "$line"
      printf "  ${BOLD}%d)${RESET} %-22s %s\n" "$((++i))" "$id" "$name"
    done <<< "$results"
    echo ""
    read -rp "Select [1-${#matches[@]}]: " choice
    if [[ ! "$choice" =~ ^[0-9]+$ ]] || (( choice < 1 || choice > ${#matches[@]} )); then
      err "Invalid selection"; exit 1
    fi
    IFS=$'\t' read -r INSTANCE_ID INSTANCE_NAME <<< "${matches[$((choice-1))]}"
    return 0
  fi
}

# Generate a unique S3 key for the transfer
s3_temp_key() {
  local filename="$1"
  local uuid
  uuid=$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid 2>/dev/null || date +%s%N)
  echo "transfers/${uuid}/${filename}"
}

# Wait for SSM command to complete and return status
wait_ssm_command() {
  local command_id="$1"
  local instance_id="$2"
  local elapsed=0
  local interval=3

  while (( elapsed < SSM_TIMEOUT )); do
    local result
    result=$(aws ssm get-command-invocation \
      --command-id "$command_id" \
      --instance-id "$instance_id" \
      $(aws_opts) \
      --output json 2>/dev/null || echo '{"Status":"Pending"}')

    local status
    status=$(echo "$result" | jq -r '.Status')

    case "$status" in
      Success)
        return 0
        ;;
      Failed|TimedOut|Cancelled|Cancelling)
        local stderr_output
        stderr_output=$(echo "$result" | jq -r '.StandardErrorContent // ""')
        [[ -n "$stderr_output" ]] && err "Remote error: $stderr_output"
        return 1
        ;;
      Pending|InProgress|Delayed)
        printf "\r  ${DIM}⏳ Waiting for remote command… (%ds)${RESET}" "$elapsed"
        sleep "$interval"
        (( elapsed += interval ))
        ;;
      *)
        sleep "$interval"
        (( elapsed += interval ))
        ;;
    esac
  done

  err "SSM command timed out after ${SSM_TIMEOUT}s"
  return 1
}

# Clean up S3 temp object
s3_cleanup() {
  local s3_key="$1"
  if [[ "$NO_CLEANUP" == true ]]; then
    info "Keeping S3 object: s3://${S3_BUCKET}/${s3_key}"
    return 0
  fi
  aws s3 rm "s3://${S3_BUCKET}/${s3_key}" $(aws_opts) &>/dev/null || true
}

# ── PUSH: local → instance ──────────────────────────────────
do_push() {
  local local_path="$1"
  local target="$2"
  local remote_path="${3:-/home/${SSM_USER}/}"

  local is_dir=false
  if [[ -d "$local_path" ]]; then
    if [[ "$RECURSIVE" != true ]]; then
      err "'${local_path}' is a directory — use -r/--recursive"
      exit 1
    fi
    is_dir=true
  elif [[ ! -f "$local_path" ]]; then
    err "Local path not found: $local_path"
    exit 1
  fi

  local filename
  if [[ "$is_dir" == true ]]; then
    filename="$(basename "$local_path").tar.gz"
  else
    filename=$(basename "$local_path")
  fi

  resolve_instance "$target"

  local display_name="${INSTANCE_NAME:-$INSTANCE_ID}"
  local s3_key
  s3_key=$(s3_temp_key "$filename")
  local s3_uri="s3://${S3_BUCKET}/${s3_key}"

  # If remote_path ends with /, append filename for files
  if [[ "$is_dir" == false && "$remote_path" == */ ]]; then
    remote_path="${remote_path}${filename}"
  fi

  step "push ${BOLD}${local_path}${RESET} → ${BOLD}${display_name}${RESET}:${remote_path}"
  echo ""

  # Step 1: Upload to S3 (tar if directory)
  info "Uploading to S3…"
  if [[ "$is_dir" == true ]]; then
    local tmp_tar
    tmp_tar=$(mktemp /tmp/s3cp-XXXXXX.tar.gz)
    trap "rm -f '$tmp_tar'" EXIT
    tar -czf "$tmp_tar" -C "$(dirname "$local_path")" "$(basename "$local_path")"
    if ! aws s3 cp "$tmp_tar" "$s3_uri" $(aws_opts) --quiet; then
      err "Failed to upload to S3"
      rm -f "$tmp_tar"
      exit 1
    fi
    rm -f "$tmp_tar"
  else
    if ! aws s3 cp "$local_path" "$s3_uri" $(aws_opts) --quiet; then
      err "Failed to upload to S3"
      exit 1
    fi
  fi
  ok "Uploaded to S3"

  # Step 2: SSM send-command to download on instance
  info "Sending download command to instance…"
  local cmd
  if [[ "$is_dir" == true ]]; then
    # Ensure remote_path ends with /
    remote_path="${remote_path%/}/"
    cmd="aws s3 cp '${s3_uri}' '/tmp/${filename}' --region '${AWS_REGION}' && mkdir -p '${remote_path}' && tar -xzf '/tmp/${filename}' -C '${remote_path}' && rm -f '/tmp/${filename}' && chown -R ${SSM_USER}:${SSM_USER} '${remote_path}'"
  else
    cmd="aws s3 cp '${s3_uri}' '${remote_path}' --region '${AWS_REGION}' && chown ${SSM_USER}:${SSM_USER} '${remote_path}'"
  fi

  local command_id
  command_id=$(aws ssm send-command \
    --instance-ids "$INSTANCE_ID" \
    --document-name "AWS-RunShellScript" \
    --parameters "commands=[\"$cmd\"]" \
    --timeout-seconds "$SSM_TIMEOUT" \
    $(aws_opts) \
    --output json | jq -r '.Command.CommandId')

  if [[ -z "$command_id" || "$command_id" == "null" ]]; then
    err "Failed to send SSM command"
    s3_cleanup "$s3_key"
    exit 1
  fi

  # Step 3: Wait for completion
  if wait_ssm_command "$command_id" "$INSTANCE_ID"; then
    printf "\r%-60s\n" ""  # clear progress line
    ok "File delivered to ${display_name}:${remote_path}"
  else
    printf "\r%-60s\n" ""
    err "Transfer failed"
    s3_cleanup "$s3_key"
    exit 1
  fi

  # Step 4: Cleanup S3
  s3_cleanup "$s3_key"
}

# ── PULL: instance → local ──────────────────────────────────
do_pull() {
  local target="$1"
  local remote_path="$2"
  local local_path="${3:-.}"

  resolve_instance "$target"

  local display_name="${INSTANCE_NAME:-$INSTANCE_ID}"
  local filename
  local is_dir=false

  if [[ "$RECURSIVE" == true ]]; then
    is_dir=true
    filename="$(basename "$remote_path").tar.gz"
  else
    filename=$(basename "$remote_path")
  fi

  local s3_key
  s3_key=$(s3_temp_key "$filename")
  local s3_uri="s3://${S3_BUCKET}/${s3_key}"

  # If local_path is a directory and not recursive, append filename
  if [[ "$is_dir" == false && -d "$local_path" ]]; then
    local_path="${local_path%/}/${filename}"
  fi

  step "pull ${BOLD}${display_name}${RESET}:${remote_path} → ${BOLD}${local_path}${RESET}"
  echo ""

  # Step 1: SSM send-command to upload from instance to S3
  info "Sending upload command to instance…"
  local cmd
  if [[ "$is_dir" == true ]]; then
    cmd="tar -czf '/tmp/${filename}' -C '$(dirname "$remote_path")' '$(basename "$remote_path")' && aws s3 cp '/tmp/${filename}' '${s3_uri}' --region '${AWS_REGION}' && rm -f '/tmp/${filename}'"
  else
    cmd="aws s3 cp '${remote_path}' '${s3_uri}' --region '${AWS_REGION}'"
  fi

  local command_id
  command_id=$(aws ssm send-command \
    --instance-ids "$INSTANCE_ID" \
    --document-name "AWS-RunShellScript" \
    --parameters "commands=[\"$cmd\"]" \
    --timeout-seconds "$SSM_TIMEOUT" \
    $(aws_opts) \
    --output json | jq -r '.Command.CommandId')

  if [[ -z "$command_id" || "$command_id" == "null" ]]; then
    err "Failed to send SSM command"
    exit 1
  fi

  # Step 2: Wait for completion
  if wait_ssm_command "$command_id" "$INSTANCE_ID"; then
    printf "\r%-60s\n" ""
    ok "File uploaded to S3 from instance"
  else
    printf "\r%-60s\n" ""
    err "Remote upload failed"
    s3_cleanup "$s3_key"
    exit 1
  fi

  # Step 3: Download from S3 to local
  info "Downloading from S3…"
  if [[ "$is_dir" == true ]]; then
    local tmp_tar
    tmp_tar=$(mktemp /tmp/s3cp-XXXXXX.tar.gz)
    if ! aws s3 cp "$s3_uri" "$tmp_tar" $(aws_opts) --quiet; then
      err "Failed to download from S3"
      rm -f "$tmp_tar"
      s3_cleanup "$s3_key"
      exit 1
    fi
    mkdir -p "$local_path"
    tar -xzf "$tmp_tar" -C "$local_path"
    rm -f "$tmp_tar"
    ok "Extracted to ${local_path}"
  else
    if ! aws s3 cp "$s3_uri" "$local_path" $(aws_opts) --quiet; then
      err "Failed to download from S3"
      s3_cleanup "$s3_key"
      exit 1
    fi
    ok "Saved to ${local_path}"
  fi

  # Step 4: Cleanup S3
  s3_cleanup "$s3_key"
}

# ── Pre-checks ───────────────────────────────────────────────
require_cmd aws
require_cmd jq
require_cmd tar

# ── Argument parsing ─────────────────────────────────────────
[[ $# -lt 1 ]] && usage 1

SUBCOMMAND=""
POSITIONAL=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    push|pull|configure)
      SUBCOMMAND="$1"; shift ;;
    -r|--recursive)
      RECURSIVE=true; shift ;;
    -b|--bucket)
      S3_BUCKET="$2"; shift 2 ;;
    -R|--region)
      AWS_REGION="$2"; shift 2 ;;
    -p|--profile)
      AWS_PROFILE="$2"; shift 2 ;;
    -u|--user)
      SSM_USER="$2"; shift 2 ;;
    -t|--timeout)
      SSM_TIMEOUT="$2"; shift 2 ;;
    --no-cleanup)
      NO_CLEANUP=true; shift ;;
    -V|--version)
      echo "s3cp v${S3CP_VERSION}"; exit 0 ;;
    -h|--help|help)
      usage 0 ;;
    -*)
      err "Unknown option: $1"; usage 1 ;;
    *)
      POSITIONAL+=("$1"); shift ;;
  esac
done

[[ -z "$SUBCOMMAND" ]] && { err "Missing command: push or pull"; usage 1; }

case "$SUBCOMMAND" in
  configure)
    do_configure
    ;;
  push)
    [[ ${#POSITIONAL[@]} -lt 2 ]] && { err "Usage: s3cp push [options] <local-path> <instance> [remote-path]"; exit 1; }
    do_push "${POSITIONAL[0]}" "${POSITIONAL[1]}" "${POSITIONAL[2]:-}"
    ;;
  pull)
    [[ ${#POSITIONAL[@]} -lt 2 ]] && { err "Usage: s3cp pull [options] <instance> <remote-path> [local-path]"; exit 1; }
    do_pull "${POSITIONAL[0]}" "${POSITIONAL[1]}" "${POSITIONAL[2]:-.}"
    ;;
esac
